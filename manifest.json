{
  "manifest_version": 3,
  "name": "DreamShop Product CSV Scraper",
  "description": "Scrape product details from user-opened Chrome tabs and export a generic shop-agnostic CSV.",
  "version": "1.0.0",
  "action": {
    "default_title": "DreamShop CSV Scraper",
    "default_popup": "src/ui/popup.html"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "downloads",
    "scripting",
    "storage",
    "tabs",
    "unlimitedStorage"
  ],

  "background": {
    "service_worker": "src/infrastructure/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "src/ui/options.html",
    "open_in_tab": true
  },
  "content_scripts": [

    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/infrastructure/pageInterceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/infrastructure/contentOverlay.js"],
      "css": ["src/ui/overlay.css"]
    }

  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}